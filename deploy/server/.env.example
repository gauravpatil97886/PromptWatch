# Copy to .env and edit. All settings use the PW_ prefix.

# REQUIRED to expose the dashboard beyond localhost. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PW_DASHBOARD_TOKEN=

# Organization display name (shown in the dashboard header).
PW_ORG_NAME=Acme Corp

# Encrypt prompts/responses at rest (recommended).
PW_ENCRYPT_LOGS=true

# Mask detected secrets before storage/transmission.
PW_REDACT_SECRETS=true

# Mask PII/PHI/PCI (SSNs, cards, emails, phones, IBANs) before storage/transmission.
PW_REDACT_PII=true

# Refuse to accept agent credentials over plain HTTP (agents enforce this too).
PW_REQUIRE_HTTPS=true

# Data retention in days (0 = keep forever). Also editable live in Admin → Settings.
PW_RETENTION_DAYS=90

# Ports (defaults shown).
# PW_COLLECTOR_PORT=9090
# PW_DASHBOARD_PORT=9100

# Postgres backend for org scale (optional; SQLite is the default).
# PW_DB_URL=postgresql://pw:pw@db/pw
